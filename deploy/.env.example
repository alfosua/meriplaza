# Copy to deploy/.env and fill in. Never commit the real .env.

# Postgres
POSTGRES_USER=salesfactory
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=salesfactory

# Connection string the services use (host "db" is the compose service name).
DATABASE_URL=postgres://salesfactory:change-me-strong-password@db:5432/salesfactory?sslmode=disable

# HTTP Basic Auth credentials shared by all services: "user:pass,user2:pass2"
API_USERS=admin:change-me-too
